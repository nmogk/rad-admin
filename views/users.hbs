{{!-- This is the administration page for references --}} 
{{#> layout title="Users" nav=1 useActive=1}} 

{{#*inline "header-block"}}
    <style>
        .table td.fit, 
        .table th.fit {
            white-space: nowrap;
            width: 1%;
        }
    </style>
{{/inline}}

{{#*inline "scripts-block"}}
    <script nonce="{{nonce}}" src="/usertools.js"></script>
{{/inline}}

{{#*inline "search-area"}}
<p>Manage users and their permissions. Normal users can view, edit, and add references, sources, and campaigns. Delete adds the ability to delete content and edit website text. Superusers can manage users and the database.</p>

<form class="form inline" method="post" action="/users/invite">
    <div class="form-group">
        <label for="email">Invite address:</label>
        <input type="email" class="form-control" id="email" name="newUserEmail">
    </div>
    <button type="submit" class="btn btn-primary">
        <span class="bi bi-gift-fill"></span> Invite New Editor
    </button>
    <a href="/users/signup/">Direct user creation.</a>
</form>

{{/inline}} 

{{#*inline "results-area"}} {{! Results header }}
<div id="mainDisplay" role="main" data-current-user-id="{{currentUserId}}">

    {{! Results group }}
    <div class="table-responsive">

        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Display Name</th>
                    <th class="fit" colspan="2">Validated</th>
                    <th class="fit">Last Login</th>
                    <th class="fit" colspan="3">Permissions</th>
                    <th class="fit">Delete</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: users">
                <tr data-bind="css: { 'info': isSelf }">
                    <td>
                        <span data-bind="text: email"></span>
                        <!-- ko if: isSelf -->
                        <span class="label label-info">(You)</span>
                        <!-- /ko -->
                    </td>
                    <td>
                        <span data-bind="text: name"></span>
                    </td>
                    <td class="fit">
                        <span data-bind="text: validated"></span>
                    </td>
                    <td class="fit">
                        <a class='btn btn-primary' data-bs-toggle="tooltip" title="Resend invitation (or administrative password reset)" data-bind="click: $parent.resendInvite">
                            <span class="bi bi-envelope-exclamation"></span>
                        </a>
                    </td>
                    <td class="fit">
                        <span data-bind="text: lastLogin"></span>
                    </td>
                    <td class="fit">
                        <button type="button" data-bind="click: $parent.updatePerms.bind($data, 0), attr: {'class': perm0}">Normal</button>
                    </td>
                    <td class="fit">
                        <button type="button" data-bind="click: $parent.updatePerms.bind($data, 1), attr: {'class': perm1}">Delete</button>
                    </td>
                    <td class="fit">
                        <button type="button" data-bind="click: $parent.updatePerms.bind($data, 2), attr: {'class': perm2}">Superuser</button>
                    </td>
                    <td class="fit">
                        <a class='btn btn-default' data-bind="click: $parent.delUser">
                            <span class="bi bi-trash3"></span>
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>

    </div>

</div>
{{/inline}} 

{{#*inline "modal-block"}} 

<div class="modal fade" id="deleteUserConfirm" role="dialog" tabindex=0>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        <h4 class="modal-title">Delete this user?</h4>
      </div>
      <div class="modal-body">
        <p>This cannot be undone! Are you sure?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal" id="confirm-delete-button">Delete</button>
        <button type="button" class="btn btn-default" data-bs-dismiss="modal" id="cancel-delete-button">Cancel</button>
      </div>
    </div>
  </div>
</div>


<div class="modal fade" id="selfActionWarning" role="dialog" tabindex=0>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        <h4 class="modal-title" id="selfActionWarningTitle">Warning</h4>
      </div>
      <div class="modal-body">
        <p id="selfActionWarningMessage"></p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-danger" id="confirm-self-action-button">Continue</button>
        <button type="button" class="btn btn-default" data-bs-dismiss="modal">Cancel</button>
      </div>
    </div>
  </div>
</div>

{{> adminHelp}}
{{/inline}} 


{{#*inline "scripts-block"}}
<script nonce="{{nonce}}" src="private/usertools.js"></script> 
{{/inline}} 
{{/layout}}