{{!--
    This is the administration page for references
--}}

{{#> layout title="References" nav=1 refActive=1}}
    
    {{#*inline "custom-title"}}
        {{!--<h2>{{title}}</h2>--}}
    {{/inline}}

    {{#*inline "header-block"}}
        {{!-- Force long unbreakable strings (e.g. URLs in author) to wrap inside
              their column instead of overflowing into the next cell. Issue #13. --}}
        <style>#mainDisplay [class*="col-sm-"] { overflow-wrap: anywhere; word-wrap: break-word; }</style>
        <style>
          @keyframes refEditFlash {
            0% { background-color: #fff3cd; }
            100% { background-color: transparent; }
          }
          .ref-edit-highlight { animation: refEditFlash 2s ease-out; }
        </style>
    {{/inline}}

    {{#*inline "search-area"}}
        <p class="text-body-secondary">Add or edit references. Search behaves the same as on the main page, or use one of the power search options below. </p>
        <form role="search" class="">
          <div class="row mb-3">
            <label for="searchInput" class="col-sm-2 col-form-label text-sm-end">Query:</label>
            <div class="col-sm-8"><input id="searchInput" class="form-control" type="search" placeholder="Type query here" name="q" aria-required="true" required autofocus list="searchHistory" data-history-key="refs"><datalist id="searchHistory"></datalist></div>
          </div>
          <div class="row mb-3">
            <label for="rowsInput" class="col-sm-2 col-form-label text-sm-end">Results per page:</label>
            <div class="col-sm-2"><input id="rowsInput" class="form-control" type="number" min="1" max="1000" value="30" name="rows"></div>
            <div class="col-sm-6 form-check">
              <label><input id="boostCheck" type="checkbox" name="boost" value="1"> Disable date boost</label>
            </div>
          </div> {{!TODO: ensure max is consistent with server max }}
          <div class="row mb-3">
            <div class="offset-sm-2 col-sm-5">
              <button type="submit" class="btn btn-primary" data-bs-toggle="tooltip" title="Search on query"><span class="bi bi-search"></span> Search</button>
              <div class="btn-group">
                <button id="blankSearchBtn" type="button" class="btn btn-primary" data-bs-toggle="tooltip" title="Search for entries with any blank field"><span class="bi bi-dash-circle"></span></button>
                <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <span class="sr-only">Choose a specific blank field</span>
                </button>
                <ul class="dropdown-menu" role="menu" aria-label="Blank field search options">
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="">Any field</a></li>
                  <li role="separator" class="divider"></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="author">Author</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="title">Title</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="reference">Reference</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="source">Source</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="page">Page</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="type">Type</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="abstract">Abstract</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="dt">Date</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="rev_author">Reviewed Author</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="rev_title">Reviewed Title</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="rev_date">Reviewed Date</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-blank-field="rev_source">Reviewed Source</a></li>
                </ul>
              </div>
              <div class="btn-group">
                <button id="oddCharSearchBtn" type="button" class="btn btn-primary" data-bs-toggle="tooltip" title="Search for entries with odd or problematic characters"><span class="bi bi-question-circle"></span></button>
                <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <span class="sr-only">Choose a specific character category</span>
                </button>
                <ul class="dropdown-menu" role="menu" aria-label="Problematic character search options">
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-odd-chars="">Any problematic</a></li>
                  <li role="separator" class="divider"></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-odd-chars="control">Control / non-printing</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-odd-chars="invisible">Invisible / zero-width</a></li>
                  <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-odd-chars="smart">Smart punctuation</a></li>
                </ul>
              </div>
              <button id="orphanSourceBtn" type="button" class="btn btn-primary" data-bs-toggle="tooltip" title="Find refs whose source is not in the source list"><span class="bi bi-arrow-up-right-circle"></span></button>
              <span id="orphanSourceProgress" class="text-muted small" style="display:none; margin-left:8px" aria-live="polite"></span>
            </div>
            <div class="col-xs-offset-right-2 col-sm-3 text-end">
              <button type="button" class="btn btn-info" href="#" data-bs-toggle="modal" data-bs-target="#newRefModal" data-bs-backdrop="static"><span class="bi bi-plus-lg"></span> Add new reference</button>
            </div>
          </div>
        </form>
        
    {{/inline}}
    
    {{#*inline "results-area"}}

        {{#if activeCampaign}}
        <div class="alert alert-info" role="status">
          Working on campaign: <strong>{{activeCampaign.name}}</strong> (<span id="activeCampaignRefCount">{{activeCampaign.refCount}}</span> refs).
          <a href="/campaigns" class="alert-link" style="margin-left: 8px;">Back to campaigns</a>
        </div>
        {{/if}}

        {{! Results header }}
        <div id="mainDisplay" aria-hidden="true" role="main">
          <div id="campaignBatchAlert" class="alert alert-warning" style="display:none" aria-live="polite">
            <strong>Showing <span id="campaignBatchShown"></span> of <span id="campaignBatchTotal"></span> refs in <span id="campaignBatchName"></span>.</strong>
            Work through these and re-open the campaign to see the next batch.
          </div>
          <div id="orphanCapAlert" class="alert alert-warning" style="display:none" aria-live="polite">
            <strong>Showing <span id="orphanCapShown"></span> of <span id="orphanCapTotal"></span> orphan refs.</strong>
            Fix these and re-run the orphan search to see the next batch.
          </div>
          <div id="res-head" class="card-body">
            <div>
              <span data-bind="text: summary"></span>
            </div>
            <div class="row">
              <div class="col-12 col-sm-3"><h4>Author</h4></div>
              <div class="col-12 col-sm-6"><h4>Title</h4></div>
              <div class="col-12 col-sm-2"><h4>Date</h4></div>
              <div class="col-12 col-sm-1"><a href="#" id="addResultsToCampaignBtn" data-bs-toggle="tooltip" title="Add current references to campaign" style="color: #000000;"><h4><span class="bi bi-list-task"></span></h4></a></div>
            </div>
            <hr>
            <div id="noResultsAlert" class="alert alert-info" aria-hidden="true" aria-live="assertive"><strong>No results!</strong> Your query did not match any references. Make sure all words are spelled correctly. Try a less complex search or alternate search terms.</div>
          </div>

          {{! Results group }}
          <div class="accordion" id="accordion" role="tablist" aria-multiselectable="true" aria-live="assertive">
          
            <!-- ko foreach: refs -->
            <div class="card">
              <div class="card-header" tabindex=0 data-bs-toggle="tooltip" title="Click to expand" role="tab" data-bind="attr: {id: ariaLab, 'data-ref-id': id}">
                <div class="row position-relative">
                  <div class="col-12 col-sm-3"><h6><span data-bind="textPretty: author">Author</span></h6></div>
                  <div class="col-12 col-sm-6"><h6><span data-bind="textPretty: title">Title</span></h6></div>
                  <div class="col-12 col-sm-2"><h6><span data-bind="textPretty: date">Date</span></h6></div>
                  <div class="col-12 col-sm-1 dropdown">
                    <button class="btn btn-link position-relative z-2" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="color: #000000;">
                      <span class="bi bi-three-dots-vertical"></span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" role="menu" aria-label="operations menu" tabindex=0>
                      <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: editRef"><span class="bi bi-pencil"></span> Edit</a></li>
                      <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: addToCampaign"><span class="bi bi-flag"></span> Add to campaign</a></li>
                      {{#if activeCampaign}}
                      <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: removeFromActiveCampaign"><span class="bi bi-x-circle"></span> Remove from this campaign</a></li>
                      {{/if}}
                      <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: viewPublisherForEditing"><span class="bi bi-eye"></span> View publisher for editing</a></li>
                      <!-- ko if: source() && source() !== publisher() -->
                      <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: viewSourceForEditing"><span class="bi bi-eye"></span> View source for editing</a></li>
                      <!-- /ko -->
                      {{#if deletable}}<li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: deleteRef"><span class="bi bi-trash3"></span> Delete reference</a></li>{{/if}}
                    </ul>
                  </div>
                  <a class="stretched-link" data-bs-toggle="collapse" data-bs-parent="#accordion" href="#collapse1" data-bind="attr: {href: '#'+colId}" aria-label="Toggle details"></a>
                </div>
              </div>
              <div class="collapse" data-bind="attr: {id: colId, 'aria-labelledby': ariaLab}" role="tabpanel">
                <div class="card-body">
                  <div class="row">
                    <div class="col-sm-5"><h4>Reference</h4><span data-bind="textPretty: reference"></span></div>
                    <div class="col-sm-5">
                      <h4>Publisher</h4><span data-bind="textPretty: publisher"></span> <button type="button" class="btn btn-link btn-sm" style="color: #000000;" data-bind="click: publisherModal"><span class="bi bi-info-square"></span></button>
                      <!-- ko if: source() && source() !== publisher() -->
                      <h4>Source</h4><span data-bind="textPretty: source"></span> <button type="button" class="btn btn-link btn-sm" style="color: #000000;" data-bind="click: sourceModal"><span class="bi bi-info-square"></span></button>
                      <!-- /ko -->
                    </div>
                    <div class="col-sm-1"><h4><span data-bind="text: pageTitle">Page</span></h4><span data-bind="textPretty: page"></span></div>
                    <div class="col-sm-1"><span class="small text-muted">id:</span><span class="small text-muted" data-bind="text: id"></span></div>
                  </div>
                  <!-- ko if: type -->
                  <p><strong>Type:</strong> <span class="text-capitalize" data-bind="text: type"></span></p>
                  <!-- /ko -->
                  <!-- ko if: rev_author() || rev_title() || rev_source() || rev_date() -->
                  <div class="row">
                    <div class="col-sm-3"><!-- ko if: rev_author --><h4>Reviewed Author</h4><span data-bind="textPretty: rev_author"></span><!-- /ko --></div>
                    <div class="col-sm-3"><!-- ko if: rev_title --><h4>Reviewed Title</h4><span data-bind="textPretty: rev_title"></span><!-- /ko --></div>
                    <div class="col-sm-2"><!-- ko if: rev_date --><h4>Reviewed Date</h4><span data-bind="textPretty: rev_date"></span><!-- /ko --></div>
                    <div class="col-sm-4"><!-- ko if: rev_source --><h4>Reviewed Source</h4><span data-bind="textPretty: rev_source"></span><!-- /ko --></div>
                  </div>
                  <!-- /ko -->
                  <h4>Abstract</h4>
                  <p data-bind="textPretty: abst" style="white-space:pre-wrap"></p>
                </div>
              </div>
            </div>
            <!-- /ko -->
            <div id="paginationAlert" class="alert alert-warning" aria-hidden="true" aria-live="polite">
              <a href='#' class='close' data-dismiss='alert' aria-label='close' tabindex=0>&times;</a>
              <strong>Warning!</strong> A 'start' value which is not evenly divisible by 'rows' or a very large 'rows' value will cause pagination to behave non-intuitively.
            </div>
          </div>
          <div id="spellingSuggestions" aria-hidden="true" aria-live="polite" class="text-center small text-muted">
            <span>Try similar terms: </span>
            <span data-bind="foreach: spellings">
              <span data-bind="foreach: suggestions"><span data-bind="if: $index">, </span><span data-bind="text: $data"></span></span>
            </span>
          </div>
          <div id="pages" class="text-center" role="navigation" aria-live="polite">
            <p id="pageSummary" data-bind="text: summary"></p>
          </div>
        </div>
    {{/inline}}

    {{#*inline "modal-block"}}
        {{> sourceModal}}

        {{> newRefModal}}

        {{> editRefModal}}

        {{> newSourceModal}}

        {{> campaignPickerModal}}

        {{> newCampaignModal fieldDocs=campaignFieldDocs}}

        {{> confirmModal}}

        {{> adminHelp}}

        <script nonce="{{nonce}}" type="application/json" id="activeCampaignData">{{json activeCampaign}}</script>

    {{/inline}}

    {{#*inline "footer-block"}}
        {{#if updated}}<p>Database updated: {{updated}} | Records: {{numRecords}} | Latest: {{latest}}.</p>{{/if}}
      
        {{> footerAdmin}}
    {{/inline}}
    
    {{#*inline "scripts-block"}}

      {{!<script> src="private/ajax-form.js"</script>}}
      <script nonce="{{nonce}}" src="javascripts/utils.js"></script>
      <script nonce="{{nonce}}" src="javascripts/refGridView.js"></script>
      <script nonce="{{nonce}}" src="javascripts/refViewModel.js"></script>
      <script nonce="{{nonce}}" src="javascripts/sourceViewModel.js"></script>
      <script nonce="{{nonce}}" src="javascripts/srcViewModel.js"></script>
      <script nonce="{{nonce}}" src="javascripts/campaignViewModel.js"></script>
      <script nonce="{{nonce}}" src="javascripts/searchHistory.js"></script>
      <script nonce="{{nonce}}" src="private/refs.js"></script>
    {{/inline}}

{{/layout}}
