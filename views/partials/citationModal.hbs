<div class="modal fade" id="citationModal" role="dialog" tabindex=0>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title">Approximately Formatted Citations</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      {{!-- Six rows (one per citation style) generated from RAD.citations.styles
            in public/javascripts/citations.js. Edit formats there, not here. --}}
      <div class="modal-body"><table>
        {{!-- The <tbody> wrapper is required: HTML5 parsers foster-parent stray
              comments out of <table>, which breaks KO's containerless ko/`/ko`
              comment pairing. Inside <tbody>, the comments are preserved. --}}
        <tbody>
        <!-- ko foreach: window.RAD.citations.styles -->
        <tr><td colspan="2"><h5 data-bind="text: label + ' Style'"></h5></td></tr>
        <tr data-bind="style: { borderBottom: $index() < window.RAD.citations.styles.length - 1 ? '1px solid gray' : '' }">
          <td><p data-bind="html: window.RAD.citations.format(id, $parent), attr: { id: id + '-citation' }"></p></td>
          <td><button class="copy" data-bind="attr: { 'data-clipboard-target': '#' + id + '-citation', 'aria-label': 'Copy ' + label + ' formatted citation to clipboard' }">
              <span class="bi bi-clipboard-plus" alt="Copy to clipboard"></span>
          </button></td>
        </tr>
        <!-- /ko -->
        </tbody>
        </table>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>