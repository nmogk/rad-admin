<div class="modal fade" id="newRefModal" role="dialog" tabindex=0>
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="close" data-bind="click: revert">&times;</button>
                <h4 class="modal-title">Add New Reference</h4>
            </div>
            <form id="refInput" data-bind="submit: $data.newRefHandler">
                <div class="modal-body">
                    <div class="alert alert-success" style="display:none" data-bind="visible: formSuccess, text: formSuccess"></div>
                    <div class="alert alert-danger" style="display:none" data-bind="visible: formError, text: formError"></div>
                    <!-- ko if: typeof oddCharReport === 'function' && oddCharReport().length -->
                    <div class="alert alert-warning">
                        <strong>Problematic characters detected.</strong> Saving will clean them automatically.
                        <ul class="list-unstyled" style="margin-bottom:0" data-bind="foreach: oddCharReport">
                            <li data-bind="text: $data"></li>
                        </ul>
                    </div>
                    <!-- /ko -->
                    {{> refFormFields}}
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-info">Save</button>
                    <button type="button" class="btn btn-primary" data-bind="click: $data.saveAndAddAnother">Save and Add Another</button>
                    <button type="button" class="btn btn-default" data-bs-dismiss="modal" data-bind="click: revert">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>
