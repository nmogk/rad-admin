{{!--
    Admin page for data-entry TODOs (issue #145).
    Two grouped lists: periodicals (with their nested issues) and general tasks.
--}}

{{#> layout title="Tasks" nav=1 tskActive=1}}

    {{#*inline "header-block"}}
        <style>
          /* Soft yellow tint on rows / periodical cards owned by the current
             editor — matches the ref-edit-flash palette. (#148) */
          .task-mine { background-color: #fff8e1; }
        </style>
    {{/inline}}

    {{#*inline "search-area"}}
        <p class="text-body-secondary">Track outstanding data-entry work. Periodicals group their issues; general tasks are freeform jobs. Editors can claim, complete, edit, and add tasks. Delete and reassignment require delete permission.</p>

        <p>
            <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#newPeriodicalModal" data-bs-backdrop="static"><span class="bi bi-plus-lg"></span> Add periodical</button>
            <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#newGeneralTodoModal" data-bs-backdrop="static"><span class="bi bi-plus-lg"></span> Add Task</button>
        </p>
    {{/inline}}

    {{#*inline "results-area"}}
        <div id="mainDisplay" role="main">

            <h3>Periodicals</h3>
            <div id="res-head" class="card-body">
                <div class="row">
                    <div class="col-12 col-sm-3"><h4>Name</h4></div>
                    <div class="col-12 col-sm-3"><h4>Publisher</h4></div>
                    <div class="col-12 col-sm-5"><h4>Issues</h4></div>
                    <div class="col-12 col-sm-1"></div>
                </div>
                <hr>
                <!-- ko if: periodicals().length === 0 -->
                <div class="alert alert-info">No periodicals yet. Click <strong>Add periodical</strong> above to create one.</div>
                <!-- /ko -->
            </div>

            <div class="accordion" id="periodicalsAccordion" role="tablist" aria-multiselectable="false">
                <!-- ko foreach: periodicals -->
                <div class="card">
                    <div class="card-header" tabindex=0 role="tab" data-bind="attr: {id: ariaLab}, css: {'task-mine': hasUserOutstanding}">
                        <div class="row position-relative">
                            <div class="col-12 col-sm-3"><h6><!-- ko if: hasUserOutstanding --><span class="bi bi-person-fill text-primary me-1" title="You have outstanding issues here" aria-label="You have outstanding issues here"></span><!-- /ko --><span data-bind="textPretty: name">Name</span></h6></div>
                            <div class="col-12 col-sm-3"><h6><span data-bind="textPretty: publisher_name">Publisher</span></h6></div>
                            <div class="col-12 col-sm-5"><h6><span data-bind="text: summary"></span></h6></div>
                            <div class="col-12 col-sm-1 dropdown">
                                <button class="btn btn-link position-relative z-2" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="color: #000000;">
                                    <span class="bi bi-three-dots-vertical"></span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" role="menu" aria-label="periodical operations" tabindex=0>
                                    <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.openAddIssue"><span class="bi bi-plus-lg"></span> Add issue</a></li>
                                    <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.openPublisher"><span class="bi bi-search"></span> Go to publisher</a></li>
                                    <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.editPeriodical"><span class="bi bi-pencil"></span> Edit</a></li>
                                    {{#if deletable}}<li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.deletePeriodical"><span class="bi bi-trash3"></span> Delete periodical</a></li>{{/if}}
                                </ul>
                            </div>
                            <a class="stretched-link" data-bs-toggle="collapse" data-bind="attr: {href: '#'+colId}" aria-label="Toggle issues"></a>
                        </div>
                    </div>
                    <div class="collapse" data-bs-parent="#periodicalsAccordion" data-bind="attr: {id: colId, 'aria-labelledby': ariaLab}" role="tabpanel">
                        <div class="card-body">
                            <div class="form-check mb-2">
                                <label><input type="checkbox" data-bind="checked: showCompleted"> Show completed issues</label>
                            </div>
                            <!-- ko if: visibleIssues().length === 0 -->
                            <p class="text-muted"><em>No issues to show.</em></p>
                            <!-- /ko -->
                            <!-- ko if: visibleIssues().length > 0 -->
                            <div class="row text-muted small fw-bold border-bottom mb-1">
                                <div class="col-sm-2">Vol/No</div>
                                <div class="col-sm-2">Date</div>
                                <div class="col-sm-4">Website</div>
                                <div class="col-sm-3">Editor</div>
                                <div class="col-sm-1 text-center">Done</div>
                            </div>
                            <!-- /ko -->
                            <!-- ko foreach: visibleIssues -->
                            <div class="row align-items-center py-1 border-bottom" data-bind="css: {'task-mine': isMine}">
                                <div class="col-sm-2"><span data-bind="text: volNoLabel"></span></div>
                                <div class="col-sm-2"><span data-bind="text: dt"></span></div>
                                <div class="col-sm-4 text-truncate"><!-- ko if: link --><a data-bind="attr: {href: link}, text: link" target="_blank" rel="noopener"></a><!-- /ko --></div>
                                <div class="col-sm-3"><span data-bind="text: editorLabel, css: {'text-muted': !editor()}"></span></div>
                                <div class="col-sm-1 d-flex align-items-center justify-content-between">
                                    <input type="checkbox" data-bind="checked: completed, click: $root.toggleIssueComplete" aria-label="Completed">
                                    <div class="dropdown">
                                        <button class="btn btn-link btn-sm p-0" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="color: #000000;">
                                            <span class="bi bi-three-dots-vertical"></span>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end" role="menu" aria-label="issue operations">
                                            <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.enterReferences"><span class="bi bi-pencil-square"></span> Enter references</a></li>
                                            <!-- ko if: !editor() -->
                                            <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.claimIssue"><span class="bi bi-flag"></span> Claim</a></li>
                                            <!-- /ko -->
                                            <!-- ko if: editor() -->
                                            <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.releaseIssue"><span class="bi bi-flag-fill"></span> Release</a></li>
                                            <!-- /ko -->
                                            {{#if deletable}}<li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.assignIssue"><span class="bi bi-person-plus"></span> Assign...</a></li>{{/if}}
                                            <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.editIssue"><span class="bi bi-pencil"></span> Edit</a></li>
                                            {{#if deletable}}<li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.deleteIssue"><span class="bi bi-trash3"></span> Delete issue</a></li>{{/if}}
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <!-- /ko -->
                            <p class="small text-muted mt-2">id: <span data-bind="text: id"></span></p>
                        </div>
                    </div>
                </div>
                <!-- /ko -->
            </div>

            <h3 class="mt-5">General Tasks</h3>
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-sm-6"><h4>Description</h4></div>
                    <div class="col-12 col-sm-2"><h4>Date</h4></div>
                    <div class="col-12 col-sm-3"><h4>Editor</h4></div>
                    <div class="col-12 col-sm-1 text-center"><h4>Done</h4></div>
                </div>
                <hr>
                <!-- ko if: generals().length === 0 -->
                <div class="alert alert-info">No general tasks yet. Click <strong>Add Task</strong> above to create one.</div>
                <!-- /ko -->
            </div>

            <div class="accordion" id="generalAccordion" role="tablist" aria-multiselectable="false">
                <!-- ko foreach: generals -->
                <div class="card">
                    <div class="card-header" tabindex=0 role="tab" data-bind="attr: {id: ariaLab}, css: {'task-mine': isMine}">
                        <div class="row position-relative align-items-center">
                            <div class="col-12 col-sm-6"><h6><span data-bind="textPretty: descriptionPreview">Description</span></h6></div>
                            <div class="col-12 col-sm-2"><h6><span data-bind="text: dt"></span></h6></div>
                            <div class="col-12 col-sm-3"><h6><span data-bind="text: editorLabel, css: {'text-muted': !editor()}"></span></h6></div>
                            <div class="col-12 col-sm-1 d-flex align-items-center justify-content-between position-relative z-2">
                                <input type="checkbox" data-bind="checked: completed, click: $root.toggleGeneralComplete" aria-label="Completed">
                                <div class="dropdown">
                                    <button class="btn btn-link btn-sm p-0" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="color: #000000;">
                                        <span class="bi bi-three-dots-vertical"></span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end" role="menu" aria-label="task operations">
                                        <!-- ko if: !editor() -->
                                        <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.claimGeneral"><span class="bi bi-flag"></span> Claim</a></li>
                                        <!-- /ko -->
                                        <!-- ko if: editor() -->
                                        <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.releaseGeneral"><span class="bi bi-flag-fill"></span> Release</a></li>
                                        <!-- /ko -->
                                        {{#if deletable}}<li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.assignGeneral"><span class="bi bi-person-plus"></span> Assign...</a></li>{{/if}}
                                        <li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.editGeneral"><span class="bi bi-pencil"></span> Edit</a></li>
                                        {{#if deletable}}<li role="presentation"><a class="dropdown-item" role="menuitem" href="#" data-bind="click: $root.deleteGeneral"><span class="bi bi-trash3"></span> Delete task</a></li>{{/if}}
                                    </ul>
                                </div>
                            </div>
                            <a class="stretched-link" data-bs-toggle="collapse" data-bind="attr: {href: '#'+colId}" aria-label="Toggle details"></a>
                        </div>
                    </div>
                    <div class="collapse" data-bs-parent="#generalAccordion" data-bind="attr: {id: colId, 'aria-labelledby': ariaLab}" role="tabpanel">
                        <div class="card-body">
                            <h4>Description</h4>
                            <p data-bind="textPretty: description" style="white-space: pre-wrap"></p>
                            <!-- ko if: link -->
                            <h4>Link</h4>
                            <p><a data-bind="attr: {href: link}, text: link" target="_blank" rel="noopener"></a></p>
                            <!-- /ko -->
                            <p class="small text-muted">id: <span data-bind="text: id"></span></p>
                        </div>
                    </div>
                </div>
                <!-- /ko -->
            </div>
        </div>
    {{/inline}}

    {{#*inline "modal-block"}}
        {{> newPeriodicalModal}}
        {{> editPeriodicalModal}}
        {{> newIssueModal}}
        {{> editIssueModal}}
        {{> newGeneralTodoModal}}
        {{> editGeneralTodoModal}}
        {{> assignEditorModal}}
        {{> confirmModal}}
        {{> adminHelp}}
    {{/inline}}

    {{#*inline "scripts-block"}}
        <script nonce="{{nonce}}" src="javascripts/utils.js"></script>
        <script nonce="{{nonce}}" src="private/issueTodoViewModel.js"></script>
        <script nonce="{{nonce}}" src="private/generalTodoViewModel.js"></script>
        <script nonce="{{nonce}}" src="private/periodicalViewModel.js"></script>
        <script nonce="{{nonce}}" src="private/tasksGridView.js"></script>
        <script nonce="{{nonce}}" type="application/json" id="periodicalsData">{{json periodicals}}</script>
        <script nonce="{{nonce}}" type="application/json" id="generalsData">{{json generals}}</script>
        <script nonce="{{nonce}}" type="application/json" id="currentUserId">{{json currentUserId}}</script>
        <script nonce="{{nonce}}" src="private/tasks.js"></script>
    {{/inline}}

{{/layout}}
