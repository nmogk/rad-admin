<div class="modal fade" id="confirmModal" role="dialog" tabindex=0 aria-modal="true" aria-labelledby="confirmModalTitle">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="confirmModalTitle">Confirm</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="confirmModalBody"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-info" id="confirmModalConfirm">Confirm</button>
                <button type="button" class="btn btn-default" data-bs-dismiss="modal" id="confirmModalCancel">Cancel</button>
            </div>
        </div>
    </div>
</div>
