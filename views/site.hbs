{{#> layout title="Site" nav=1 sitActive=1}}

    {{#*inline "header-block"}}
    <style>
        .section-editor textarea {
            font-family: monospace;
            font-size: 13px;
            min-height: 400px;
            resize: vertical;
        }
        .section-meta {
            color: #777;
            font-size: 12px;
            margin-bottom: 10px;
        }
    </style>
    {{/inline}}

    {{#*inline "search-area"}}
    <p class="text-body-secondary">Edit the public-facing website content. Changes are reflected immediately on the homepage.</p>
    {{/inline}}

    {{#*inline "results-area"}}
    <div id="mainDisplay" role="main">
        <ul class="nav nav-tabs" role="tablist" data-bind="foreach: sectionList">
            <li class="nav-item" role="presentation">
                <a class="nav-link" href="#" data-bind="text: label, click: function() { $root.selectSection(key); }, css: { active: $root.selectedKey() === key }"></a>
            </li>
        </ul>

        <div class="tab-content" style="padding-top: 20px;">
            <!-- ko if: currentSection -->
            <div class="section-editor">
                <div class="alert alert-secondary py-2 mb-3" role="status">
                    Editing section <strong data-bind="text: selectedLabel"></strong>
                    (<code data-bind="text: selectedKey"></code>)
                </div>
                <div class="mb-3">
                    <label>Section Title</label>
                    <input type="text" class="form-control" data-bind="textInput: currentSection().title" placeholder="Section title">
                </div>
                <div class="mb-3">
                    <label>Content (HTML)</label>
                    <textarea class="form-control" data-bind="textInput: currentSection().content"></textarea>
                </div>
                <div class="section-meta" data-bind="visible: currentSection().updated_by">
                    Last updated by <span data-bind="text: currentSection().updated_by"></span>
                    on <span data-bind="text: currentSection().updated_at_display"></span>
                </div>
                {{#if editable}}
                <button class="btn btn-primary" data-bind="click: save">
                    <span class="bi bi-floppy2-fill"></span> <span data-bind="text: 'Save ' + selectedLabel()"></span>
                </button>
                <button class="btn btn-secondary" data-bind="click: togglePreview">
                    <span class="bi bi-eye"></span>
                    <span data-bind="text: showPreview() ? 'Hide Preview' : 'Show Preview'"></span>
                </button>
                <button class="btn btn-warning" data-bind="click: resetFromFile">
                    <span class="bi bi-arrow-counterclockwise"></span> Reset from file
                </button>
                {{/if}}
            </div>
            <!-- ko if: showPreview -->
            <div class="card card-body" style="margin-top: 15px;">
                <h4>Preview of <span data-bind="text: selectedLabel"></span></h4>
                <hr>
                <div data-bind="html: currentSection().content"></div>
            </div>
            <!-- /ko -->
            <!-- /ko -->

            <!-- ko ifnot: currentSection -->
            <div class="alert alert-info">
                No content sections found. Run the seed script to populate initial content.
            </div>
            <!-- /ko -->
        </div>
    </div>
    {{/inline}}

    {{#*inline "modal-block"}}
    {{> adminHelp}}
    {{> confirmModal}}
    <div id="previewContainer"></div>
    {{/inline}}

    {{#*inline "scripts-block"}}
    <script nonce="{{nonce}}">
        var siteContentData = {{{sectionsJson}}};
    </script>
    <script nonce="{{nonce}}" src="javascripts/utils.js"></script>
    <script nonce="{{nonce}}" src="private/site.js"></script>
    {{/inline}}

{{/layout}}
