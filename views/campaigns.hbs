{{!--
    This is the administration page for campaigns
--}}

{{#> layout title="Campaigns" nav=1 cmpActive=1}}

    {{#*inline "search-area"}}
        <p>A campaign is a named cleanup task plus a list of references that need it. Build one here, then on the references page add individual refs or whole pages of search results to it. Open a campaign in references to work through its refs and remove them as they're handled.</p>

        <p>
            <button type="button" class="btn btn-info" data-toggle="modal" data-target="#newCampaignModal" data-backdrop="static"><span class="glyphicon glyphicon-plus"></span> Add new campaign</button>
        </p>
    {{/inline}}

    {{#*inline "results-area"}}
        <div id="mainDisplay" role="main">
            <div id="res-head" class="panel-body">
                <div class="row">
                    <h4>
                        <span class="col-sm-4">Name</span>
                        <span class="col-sm-6">Description</span>
                        <span class="col-sm-1 text-right">Refs</span>
                        <span class="col-sm-1"></span>
                    </h4>
                </div>
                <hr>
                <!-- ko if: campaigns().length === 0 -->
                <div class="alert alert-info">No campaigns yet. Click <strong>Add new campaign</strong> above to create one.</div>
                <!-- /ko -->
            </div>

            <div class="panel-group" id="accordion" role="tablist" aria-multiselectable="true">
                <!-- ko foreach: campaigns -->
                <div class="panel panel-default">
                    <div class="panel-heading" tabindex=0 role="tab" data-bind="attr: {id: ariaLab}">
                        <div class="row">
                            <a data-toggle="collapse" data-parent="#accordion" data-bind="attr: {href: '#'+colId}" style="color: #000000;">
                                <div class="col-sm-4"><h5><span data-bind="textPretty: name">Name</span></h5></div>
                                <div class="col-sm-6"><h5><span data-bind="textPretty: descriptionPreview">Description</span></h5></div>
                                <div class="col-sm-1 text-right"><h5><span data-bind="text: refCount"></span></h5></div>
                            </a>
                            <div class="dropdown col-sm-1" aria-haspopup="true">
                                <button class="btn btn-link dropdown-toggle" type="button" data-toggle="dropdown" style="color: #000000;">
                                    <span class="glyphicon glyphicon-option-vertical"></span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-right" role="menu" aria-label="campaign operations" tabindex=0>
                                    <li role="presentation"><a role="menuitem" href="#" data-bind="click: editCampaign"><span class="glyphicon glyphicon-pencil"></span> Edit</a></li>
                                    <li role="presentation"><a role="menuitem" href="#" data-bind="click: openInRefs"><span class="glyphicon glyphicon-search"></span> Open in references</a></li>
                                    {{#if deletable}}<li role="presentation"><a role="menuitem" href="#" data-bind="click: deleteCampaign"><span class="glyphicon glyphicon-trash"></span> Delete</a></li>{{/if}}
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="panel-collapse collapse" data-bind="attr: {id: colId, 'aria-labelledby': ariaLab}" role="tabpanel">
                        <div class="panel-body">
                            <h4>Description</h4>
                            <p data-bind="textPretty: description" style="white-space: pre-wrap"></p>
                            <p class="small text-muted">id: <span data-bind="text: id"></span></p>
                        </div>
                    </div>
                </div>
                <!-- /ko -->
            </div>
        </div>
    {{/inline}}

    {{#*inline "modal-block"}}
        {{> newCampaignModal}}

        {{> editCampaignModal}}

        {{> confirmModal}}

        {{> adminHelp}}
    {{/inline}}

    {{#*inline "scripts-block"}}
        <script nonce="{{nonce}}" src="javascripts/utils.js"></script>
        <script nonce="{{nonce}}" src="javascripts/campaignViewModel.js"></script>
        <script nonce="{{nonce}}" src="javascripts/campaignGridView.js"></script>
        <script nonce="{{nonce}}" type="application/json" id="campaignsData">{{json campaigns}}</script>
        <script nonce="{{nonce}}" src="private/campaigns.js"></script>
    {{/inline}}

{{/layout}}
