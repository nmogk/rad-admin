{{#> layout title="Login"}}
    {{#*inline "custom-title"}}<h1><span class="bi bi-box-arrow-in-right"></span> Login</h1>{{/inline}}  
    
    {{#*inline "search-area"}}
        <div class="col-sm-6 offset-sm-3">
            <!-- LOGIN FORM -->
            <form action="/login" method="post">
                {{{csrf}}}
                <div class="mb-3">
                    <label>Email</label>
                    <input type="text" class="form-control" name="email" required autofocus>
                </div>
                <div class="mb-3">
                    <label>Password</label>
                    <input type="password" class="form-control" name="password">
                </div>

                <button type="submit" class="btn btn-primary" name="action" value="login">Login</button>
                <button type="submit" formaction="/login/forgot" class="btn btn-link" name="action" value="forgot">Password reset</button>
            </form>

            <hr>

            <p>Need an account? Please contact the site administrator.</p>
            <p>Or go <a href="/">home</a>.</p>

        </div>
    {{/inline}}  

    {{#*inline "footer-block"}}
        {{> footerBasic}}
    {{/inline}}
    
{{/layout}}