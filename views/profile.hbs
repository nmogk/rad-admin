{{#> layout title="Profile" nav=1}}
    {{#*inline "custom-title"}}<h1>{{username}}</h1>{{/inline}}  
    
    {{#*inline "search-area"}}
        <a href='/profile/password' class="btn btn-primary" ><span class="bi bi-wrench"></span> Update Password</a><a href="#" class="btn btn-link" data-bs-toggle="modal" data-bs-target="#deleteModal"><span class="bi bi-trash3"></span> Delete Account</a>
    {{/inline}}   


    {{#*inline "results-area"}}
        <dl>
            <dt>Display Name: <a href='#' class="btn btn-link" data-bs-toggle="modal" data-bs-target="#dispNameModal"><span class="bi bi-pencil-fill"></span> Change</a></dt>
            <dd>{{#if dispname}}{{dispname}}{{else}}(Not added yet){{/if}}</dd>
            <dt>Email: <a href="#" class="btn btn-link" data-bs-toggle="modal" data-bs-target="#emailModal"><span class="bi bi-pencil-fill"></span> Change</a></dt>
            <dd>{{email}}{{#if pendingEmail}} <span class="badge text-bg-warning">Pending change to {{pendingEmail}} &mdash; check your inbox</span>{{/if}}</dd>
        </dl>
    {{/inline}}  

    {{#*inline "modal-block"}}

    <div class="modal fade" id="dispNameModal" role="dialog" tabindex=0>
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h4 class="modal-title">Change Display Name</h4>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form class="" method="post">
            <div class="modal-body">
              <div class="mb-3">
                <label for="name" class="form-label">Display Name:</label>
                <input name="name" class="form-control" type="text" placeholder="{{#if dispname}}{{dispname}}{{else}}Type Name here{{/if}}">
              </div> 
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </form>
        </div>
      </div>
    </div>
    
    <div class="modal fade" id="emailModal" role="dialog" tabindex=0>
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h4 class="modal-title">Change Email Address</h4>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form class="" method="post">
            <div class="modal-body">
              <div class="mb-3">
                <label for="email" class="form-label">Email:</label>
                <input name="email" class="form-control" type="email" placeholder="{{email}}">
              </div> 
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </form>
        </div>
      </div>
    </div>  

    <div class="modal fade" id="deleteModal" role="dialog" tabindex=0>
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h4 class="modal-title">Delete Account</h4>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
            <div class="modal-body">
              <p>Are you sure you want to delete? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" id="deleteSelfConfirm" class="btn btn-danger">Delete</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
      </div>
    </div>  
    
    {{/inline}} 
    {{#*inline "scripts-block"}}
        <script nonce="{{nonce}}">

            function sendDelete(){
                $.ajax({
                    method: 'DELETE'
                });

                window.location.reload(true);

            }

            document.addEventListener('DOMContentLoaded', function () {
              document.getElementById('deleteSelfConfirm')
              .addEventListener('click', sendDelete);
          });

        </script>
    {{/inline}} 
{{/layout}}