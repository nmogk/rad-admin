{{!--
    This is the default search page for public facing users
--}}

{{#> layout title="Research Assistance Database"}}

    {{#*inline "header-block"}}
        {{!-- Force long unbreakable strings (e.g. URLs in author) to wrap inside
              their column instead of overflowing into the next cell. Issue #13. --}}
        <style>#mainDisplay [class*="col-sm-"] { overflow-wrap: anywhere; word-wrap: break-word; }</style>
    {{/inline}}

    {{#*inline "search-area"}}
        <p class="text-body-secondary">Use the query bar below to search the most comprehensive database of creationist abstracts, popular and technical.  <a href="#" id="showStoryLink">Read</a> our story. View your <a target="printer" href="aggregator.html">saved references</a>. View search <a href="#" style="cursor: pointer" data-bs-toggle="modal" data-bs-target="#searchHelp">help</a> or <a href="https://github.com/nmogk/rad-admin/issues/new">report</a> an issue.</p><p class="text-body-secondary"> (To see the abstract and other detailed information, click on the desired row in the results.)</p>

        <form role="search" class="">
          <div class="row mb-3">
            <label for="searchInput" class="col-sm-2 col-form-label">Query:</label>
            <div class="col-sm-8"><input id="searchInput" class="form-control" type="search" placeholder="Type query here" name="q" aria-required="true" required autofocus></div>
          </div>
          <div class="row mb-3">
            <label for="rowsInput" class="col-sm-2 col-form-label">Results per page:</label>
            <div class="col-sm-2"><input id="rowsInput" class="form-control" type="number" min="1" max="1000" value="30" name="rows"></div>
            <label for="typeInput" class="col-sm-1 col-form-label">Ref Type (experimental):</label>
            <div class="col-sm-2">
              <select id="typeInput" class="form-control" name="type">
                <option value="">Any type</option>
                {{#each refTypes}}
                <option value="{{value}}">{{label}}</option>
                {{/each}}
              </select>
            </div>
            <div class="col-sm-3 form-check">
              <label><input id="boostCheck" type="checkbox" name="boost" value="1"> Disable date boost</label>
            </div>
          </div> {{!TODO: ensure max is consistent with server max }}
          <div class="row mb-3">
            <div class="offset-sm-2 col-sm-10"><button type="submit" class="btn btn-primary"><span class="bi bi-search"></span> Search</button></div></div>
        </form>
        
    {{/inline}}
    
    {{#*inline "results-area"}}
        <div id="story" role="complementary" aria-hidden="true" aria-live="assertive">
            {{#if backstory}}{{{backstory}}}{{else}}{{> backstoryContents}}{{/if}}

            <div class="text-center">
                <button class="btn btn-secondary" id="hideStoryButton">Return to Search Results</button>
            </div>
        </div>

        {{! Results header }}
        <div id="mainDisplay" aria-hidden="true" role="main">
          <div id="res-head" class="card-body">
            <div>
              <span data-bind="text: summary"></span>
            </div>
            <div class="row">
              <h4>
                <span class="col-sm-3">Author</span>
                <span class="col-sm-6">Title</span>
                <span class="col-sm-2">Date</span>
                <span class="col-sm-1"><a href="#" data-bind="click: downloadList" data-bs-toggle="tooltip" title="Download results (.csv)" style="color: #000000;"><span class="bi bi-filetype-csv"></span></a></span>
              </h4>
            </div>
            <hr>
            <div id="noResultsAlert" class="alert alert-info" aria-hidden="true" aria-live="assertive"><strong>No results!</strong> Your query did not match any references. Make sure all words are spelled correctly. Try a less complex search or alternate search terms.</div>
          </div>

          {{! Results group }}
          <div class="accordion" id="accordion" role="tablist" aria-multiselectable="true" aria-live="assertive">
          
            <!-- ko foreach: refs -->
            <div class="card">
              <div class="card-header" tabindex=0 data-bs-toggle="tooltip" title="Click to expand" role="tab" data-bind="attr: {id: ariaLab}">
              <div class="row">
                  <a data-bs-toggle="collapse" data-bs-parent="#accordion" href="#collapse1" data-bind="attr: {href: '#'+colId}" style="color: #000000;">
                    <div class="col-sm-3"><h5><span data-bind="textPretty: author">Author</span></h5></div>
                    <div class="col-sm-6"><h5><span data-bind="textPretty: title">Title</span></h5></div>
                    <div class="col-sm-2"><h5><span data-bind="textPretty: date">Date</span></h5></div>
                  </a>
                  <div class="dropdown col-sm-1" aria-haspopup="true">
                    <button class="btn btn-link" type="button" data-bs-toggle="dropdown" style="color: #000000;">
                    <span class="bi bi-three-dots-vertical"></span></button>
                    <ul class="dropdown-menu dropdown-menu-right" role="menu" aria-label="operations menu" tabindex=0>
                      <li role="presentation"><a role="menuitem" href="#" target="_blank" data-bind="click: goSource"><span class="bi bi-link-45deg"></span> Go to source</a></li>
                      <li role="presentation"><a role="menuitem" href="#" data-bind="click: generateCitation"><span class="bi bi-clipboard-plus"></span> Copy citation</a></li>
                      <li role="presentation"><a role="menuitem" href="#" data-bind="click: downloadCitation"><span class="bi bi-bookmark"></span> Save reference</a></li>
                    </ul>
                  </div>
                </div>
              </div>
              <div class="collapse" data-bind="attr: {id: colId, 'aria-labelledby': ariaLab}" role="tabpanel">
                <div class="card-body">
                  <div class="row">
                    <div class="col-sm-5"><h4>Reference</h4><span data-bind="textPretty: reference"></span></div>
                    <div class="col-sm-5">
                      <h4>Publisher</h4><span data-bind="textPretty: publisher"></span> <button type="button" class="btn btn-link btn-sm" style="color: #000000;" data-bind="click: publisherModal"><span class="bi bi-info-square"></span></button>
                      <!-- ko if: source() && source() !== publisher() -->
                      <h4>Source</h4><span data-bind="textPretty: source"></span> <button type="button" class="btn btn-link btn-sm" style="color: #000000;" data-bind="click: sourceModal"><span class="bi bi-info-square"></span></button>
                      <!-- /ko -->
                    </div>
                    <div class="col-sm-1"><h4><span data-bind="text: pageTitle">Page</span></h4><span data-bind="textPretty: page"></span></div>
                    <div class="col-sm-1"><span class="small text-muted">id:</span><span class="small text-muted" data-bind="text: id"></span></div>
                  </div>
                  <!-- ko if: rev_author() || rev_title() || rev_source() || rev_date() -->
                  <div class="row">
                    <div class="col-sm-3"><!-- ko if: rev_author --><h4>Reviewed Author</h4><span data-bind="textPretty: rev_author"></span><!-- /ko --></div>
                    <div class="col-sm-3"><!-- ko if: rev_title --><h4>Reviewed Title</h4><span data-bind="textPretty: rev_title"></span><!-- /ko --></div>
                    <div class="col-sm-2"><!-- ko if: rev_date --><h4>Reviewed Date</h4><span data-bind="textPretty: rev_date"></span><!-- /ko --></div>
                    <div class="col-sm-4"><!-- ko if: rev_source --><h4>Reviewed Source</h4><span data-bind="textPretty: rev_source"></span><!-- /ko --></div>
                  </div>
                  <!-- /ko -->
                  <h4>Abstract</h4>
                  <p data-bind="textPretty: abst" style="white-space:pre-wrap"></p>
                </div>
              </div>
            </div>
            <!-- /ko -->
            <div id="paginationAlert" class="alert alert-warning" aria-hidden="true" aria-live="polite">
              <a href='#' class='close' data-dismiss='alert' aria-label='close' tabindex=0>&times;</a>
              <strong>Warning!</strong> A 'start' value which is not evenly divisible by 'rows' or a very large 'rows' value will cause pagination to behave non-intuitively.
            </div>
          </div>
          <div id="spellingSuggestions" aria-hidden="true" aria-live="polite" class="text-center small text-muted">
            <span>Try similar terms: </span>
            <span data-bind="foreach: spellings">
              <span data-bind="foreach: suggestions"><span data-bind="if: $index">, </span><span data-bind="text: $data"></span></span>
            </span>
          </div>
          <div id="pages" class="text-center" role="navigation" aria-live="polite">
            <p id="pageSummary" data-bind="text: summary"></p>
          </div>
        </div>
    {{/inline}}

    {{#*inline "modal-block"}}
        {{> sourceModal}}

        {{> citationModal}}

        {{#if search_help}}{{{search_help}}}{{else}}{{> searchHelp}}{{/if}}

        {{#if rest_help}}{{{rest_help}}}{{else}}{{> restHelp}}{{/if}}      
    {{/inline}}
    
    {{#*inline "footer-block"}}
        {{#if updated}}<p>Database updated: {{updated}} | Records: {{numRecords}} | Latest: {{latest}}.</p>{{/if}}

        {{> footerBasic}} Search via <a href="#" style="cursor: pointer" data-bs-toggle="modal" data-bs-target="#restApi">REST API</a>. <a href="/refs">Administration</a>.
    {{/inline}}
    
    {{#*inline "scripts-block"}}
        <script nonce="{{nonce}}" src="javascripts/FileSaver.min.js"></script>
        <script nonce="{{nonce}}" src="javascripts/Blob.js"></script>
        <script nonce="{{nonce}}" src="javascripts/utils.js"></script>
        <script nonce="{{nonce}}" src="javascripts/refGridView.js"></script>
        <script nonce="{{nonce}}" src="javascripts/refViewModel.js"></script>
        <script nonce="{{nonce}}" src="javascripts/sourceViewModel.js"></script>
        <script nonce="{{nonce}}" src="javascripts/citations.js"></script>
        {{! This script refers to specific elements on the page, so must be loaded last}}
        <script nonce="{{nonce}}" src="javascripts/index.js"></script>
    {{/inline}}

{{/layout}}
