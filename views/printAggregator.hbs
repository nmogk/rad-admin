{{#> layout title="Saved References"}}

    {{#*inline "header-block"}}
        <style type="text/css">
            /* Per-row remove-X. Was BS3 .close before the migration; renamed
               to .close-x so it doesn't collide with BS5's modal .btn-close.
               Restores the BS3 .close visual: small floated X with hover. */
            .close-x { float: right; font-size: 1.5rem; font-weight: 700; line-height: 1;
                color: #000; opacity: 0.5; text-decoration: none; padding: 0 .25rem; }
            .close-x:hover, .close-x:focus { opacity: 0.75; text-decoration: none; color: #000; }
        </style>
        <style media="print" type="text/css">
            @media print {
                body * {
                    visibility: hidden;
                }
                #printSet * {
                    visibility: visible;
                    float: none;
                }
                #printSet {
                    position: absolute;
                    left: 0;
                    top: 0;
                }
                a, .copy-citation, #citationStylePicker {
                    display: none;
                }
            }
        </style>
    {{/inline}}

    {{#*inline "custom-title"}}
        <h1>Research Assistance Database</h1>
        <h2>{{title}}</h2>
    {{/inline}}

    {{#*inline "search-area"}}
        <p class="text-body-secondary">Use this page to collect references to print. Each reference you select on the main search results page with the <span style="white-space: nowrap;">&quot;<span class="bi bi-bookmark"></span> Save reference&quot;</span> menu option will appear below, formatted for easy printing. Use  the buttons below to print or start a new list. Lists are persistent across browser restarts.</p>
        <a href="#" class="btn btn-primary" id="printListButton"><span class="bi bi-printer-fill"></span> Print</a><a href="#" class="btn btn-secondary" id="clearListButton"><span class="bi bi-trash3"></span> Clear</a>
    {{/inline}}

    {{#*inline "results-area"}}
        <div id="aggregatorRoot">
            <div id="citationStylePicker" class="form-inline" style="margin-bottom: 12px;">
                <label for="citationStyle" style="margin-right: 6px;">Citation style:</label>
                <select id="citationStyle" class="form-control" style="display: inline-block; width: auto;"
                        data-bind="options: styles, optionsText: 'label', optionsValue: 'id', value: selectedStyle"></select>
            </div>
            <div class="accordion" id="printSet" role="tablist">
                <!-- ko foreach: refs -->
                <div class="card">
                    <div class="card-header" role="tab">
                        <a href="#" class="close-x" data-bind="click: $parent.removeOne" aria-label="close" tabindex=0>&times;</a>
                        <div class="row">
                            <div class="col-12 col-sm-4"><h5><span data-bind="text: author">Author</span></h5></div>
                            <div class="col-12 col-sm-6"><h5><span data-bind="text: title">Title</span></h5></div>
                            <div class="col-12 col-sm-1"><h5><span data-bind="text: date">Date</span></h5></div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-sm-4"><h4>Reference</h4><span data-bind="text: reference"></span></div>
                            <div class="col-sm-6"><h4>Source</h4><span data-bind="text: source"></span></div>
                            <div class="col-sm-2"><h4>Page</h4><span data-bind="text: page"></span></div>
                        </div>
                        <h4>Abstract</h4>
                        <p data-bind="text: abstract"></p>
                        <h4>Citation</h4>
                        <p data-bind="html: $parent.formatCitation($data), attr: { id: 'citation-' + $index() }" style="display: inline-block; margin-right: 8px;"></p>
                        <button type="button" class="btn btn-secondary btn-sm copy copy-citation"
                                data-bind="attr: { 'data-clipboard-target': '#citation-' + $index() }"
                                aria-label="Copy citation to clipboard">
                            <span class="bi bi-clipboard-plus"></span>
                        </button>
                    </div>
                </div>
                <!-- /ko -->
            </div>
        </div>
    {{/inline}}

    {{#*inline "scripts-block"}}
        <script nonce="{{nonce}}" src="javascripts/citations.js"></script>
        <script nonce="{{nonce}}">
            var store = 'printRefs';
            var styleStore = 'printRefsCitationStyle';

            document.addEventListener('DOMContentLoaded', function () {
                document.getElementById('printListButton')
                        .addEventListener('click', function(){window.print();});
            });

            // Deletes the contents of the localStorage key and refreshes the page
            function clearPrintList(){
                localStorage[store] = null;
                window.location.reload(false);
            }

            document.addEventListener('DOMContentLoaded', function () {
                document.getElementById('clearListButton')
                        .addEventListener('click', clearPrintList);
            });


            // View model for the saved-references list and the citation-style
            // picker that drives per-ref inline citations (#93).
            function PrinterViewModel(){
                var self = this;

                self.refs = ko.observableArray();
                self.styles = window.RAD.citations.styles;
                self.selectedStyle = ko.observable(localStorage[styleStore] || self.styles[0].id);
                // Persist the picker choice across reloads, same way refs persist.
                self.selectedStyle.subscribe(function (v) { localStorage[styleStore] = v; });

                if(localStorage[store]){
                    var refsArray = JSON.parse(localStorage[store]);
                    for (var i = 0; refsArray && i < refsArray.length; i++) {
                        self.refs.push(refsArray[i]);
                    }
                }

                // Called from the per-ref binding; reads selectedStyle so the
                // computed re-runs when the picker changes.
                self.formatCitation = function (ref) {
                    return window.RAD.citations.format(self.selectedStyle(), ref);
                };

                // Remove an individual entry from the print list by ID.
                // Updates the localStorage list
                self.removeOne = function (ref) {
                    self.refs.remove(ref);
                    localStorage[store] = JSON.stringify(self.refs())
                }
            }

            if(typeof(Storage) !== "undefined" ){
                ko.applyBindings(new PrinterViewModel(), $('#aggregatorRoot')[0]);
                initBootstrapWidgets('#aggregatorRoot');
                new ClipboardJS('.copy-citation');
            } else {
                alert("HTML5 storage must be available for the print function to work. Try a newer browser.");
            }

        </script>
    {{/inline}}

    {{#*inline "footer-block"}}
        {{> footerBasic}}
    {{/inline}}

{{/layout}}